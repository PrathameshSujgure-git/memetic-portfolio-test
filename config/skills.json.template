      "description_for_humans": "80-point visual quality check on typography, spacing, colors, accessibility and layout consistency",
      "description_for_agent": "Run 80-item visual audit on changed pages. Read changed CSS/TSX/SVG files. Take screenshots of affected pages. Check: typography consistency (12 items), spacing system (10), color palette adherence (8), layout/grid (12), accessibility/contrast (15), design system consistency (10), responsiveness (13). Group findings by severity: critical (must fix), warning (should fix), info (nice to have). Report pass count. If critical issues found and autofix possible (spacing/typography), suggest fixes.",
      "min_role": "editor",
      "slack_emoji": "art",
      "result_format": "checklist",
      "estimated_duration": "20-40s",
      "can_autofix": "partial",
      "tooling": {
        "optional_tools": ["axe"],
        "with_tools": "Run axe-core on affected pages for real WCAG compliance data. Merge axe findings into the 80-point checklist under the Accessibility category. Hard numbers (contrast 3.2:1 vs required 4.5:1) replace LLM estimates.",
        "without_tools": "LLM evaluates accessibility from screenshots and code. Catches most issues but may miss exact contrast ratios or ARIA violations."
