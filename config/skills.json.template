  "tool_detection": {
    "_comment": "On startup, the agent runs 'which <tool>' for each CLI tool below. If available, the skill upgrades to use real tooling. If not, falls back to prompt-only analysis. Both work — tools just give harder data.",
    "tools": {
      "lighthouse": {
        "check": "which lighthouse",
        "install": "npm i -g lighthouse",
        "upgrades": ["benchmark"],
        "what_it_adds": "Real Core Web Vitals scores (LCP, CLS, FID, TBT, SI) instead of estimates from Browser Tool observation"
      },
      "eslint": {
        "check": "which eslint || npx eslint --version",
        "install": "npm i -D eslint",
        "upgrades": ["code-review"],
        "what_it_adds": "Static analysis: catches unused vars, unreachable code, complexity warnings, and project-specific lint rules"
      },
      "tsc": {
        "check": "which tsc || npx tsc --version",
        "install": "npm i -D typescript",
        "upgrades": ["code-review", "qa"],
        "what_it_adds": "Type checking: catches type errors, missing properties, incorrect function signatures before runtime"
      },
      "npm_audit": {
        "check": "npm audit --json 2>/dev/null | head -1",
        "install": "(built into npm)",
        "upgrades": ["security-scan"],
        "what_it_adds": "Real CVE database lookup on all dependencies — catches known vulnerabilities that pattern matching misses"
      },
      "semgrep": {
        "check": "which semgrep",
        "install": "pip install semgrep",
        "upgrades": ["security-scan"],
        "what_it_adds": "SAST rules for injection, auth bypass, crypto misuse — thousands of community rules across languages"
      },
      "playwright": {
        "check": "npx playwright --version 2>/dev/null",
        "install": "npm i -D @playwright/test && npx playwright install",
        "upgrades": ["qa", "browse"],
        "what_it_adds": "Real browser automation: can run existing test suites, interact with complex UIs, test across Chrome/Firefox/Safari"
      },
      "axe": {
        "check": "npx @axe-core/cli --version 2>/dev/null",
        "install": "npm i -D @axe-core/cli",
        "upgrades": ["design-audit"],
        "what_it_adds": "Real accessibility audit: WCAG 2.1 AA/AAA compliance, contrast ratios, ARIA validation — not estimates"
      }
    }
  },
