  "skill_router": {
    "_comment": "The agent auto-picks skills based on context signals. No user input needed. Each signal type maps to detection logic and which skills to run.",

    "signals": {
      "visual-change": {
        "detect_by": "files",
        "file_patterns": ["*.css", "*.scss", "*.svg", "*.png", "*.jpg", "*.jpeg", "*.webp", "*.gif"],
        "content_patterns": ["className", "style=", "tailwind", "color:", "font-", "margin", "padding", "gap", "grid", "flex", "bg-", "text-", "border-", "rounded", "shadow"],
        "skills": ["design-audit"],
        "weight": "normal"
      },
      "logic-change": {
        "detect_by": "files",
        "file_patterns": ["*.ts", "*.tsx", "*.js", "*.jsx", "*.py", "*.go", "*.rs"],
        "exclude_patterns": ["*.test.*", "*.spec.*", "*.stories.*"],
        "content_patterns": ["function", "async", "await", "fetch", "query", "mutation", "api", "handler", "middleware"],
        "skills": ["code-review"],
        "weight": "normal"
      },
      "content-only-change": {
        "detect_by": "files",
        "file_patterns": ["*.json", "*.md", "*.mdx", "*.yaml", "*.yml", "*.txt"],
        "skills": [],
        "weight": "skip-unless-relevant",
        "_comment": "Pure content edits need no skills — just ship it"
      },
      "api-or-auth-change": {
        "detect_by": "content",
        "content_patterns": ["password", "token", "secret", "auth", "login", "session", "cookie", "jwt", "oauth", "csrf", "cors", "helmet", "sanitize", "encrypt", "hash", "bcrypt", "api/", "route.ts", "middleware"],
        "skills": ["security-scan", "code-review"],
        "weight": "high",
        "_comment": "Security-sensitive changes get escalated automatically"
      },
      "dependency-change": {
        "detect_by": "files",
        "file_patterns": ["package.json", "package-lock.json", "yarn.lock", "pnpm-lock.yaml", "requirements.txt", "go.mod", "Cargo.toml"],
        "skills": ["security-scan"],
        "weight": "high",
        "_comment": "New dependencies = new attack surface"
      },
      "first-change-in-thread": {
        "detect_by": "context",
        "condition": "thread has 0 previous commits",
        "skills": [],
        "weight": "skip-unless-relevant",
        "_comment": "First change: let the user see results before running deep analysis"
      },
      "third-plus-iteration": {
        "detect_by": "context",
        "condition": "thread has 3+ commits on same files",
        "skills": ["design-audit"],
        "weight": "normal",
        "_comment": "Lots of iteration on same area = time for a quality check"
      },
      "pre-merge": {
        "detect_by": "command",
        "command": "!merge",
        "skills": ["qa", "security-scan"],
        "weight": "critical",
        "_comment": "Gate before production. Always run enabled gate skills."
      },
      "post-deploy": {
        "detect_by": "event",
        "event": "merge-complete",
        "skills": ["canary-monitor", "release-docs"],
        "weight": "critical"
      },
      "large-diff": {
        "detect_by": "diff_size",
        "threshold": "10+ files or 200+ lines changed",
        "skills": ["code-review", "qa"],
        "weight": "high",
        "_comment": "Big changes deserve deeper review"
      },
      "user-asks-question": {
        "detect_by": "intent",
        "patterns": ["what should we build", "is this a good idea", "what do you think about", "should we", "product direction", "roadmap"],
        "skills": ["office-hours"],
        "weight": "normal"
      },
      "user-asks-about-design": {
        "detect_by": "intent",
        "patterns": ["design system", "brand", "visual direction", "look and feel", "redesign", "design language"],
        "skills": ["design-consultation"],
        "weight": "normal"
      },
      "user-reports-bug": {
        "detect_by": "intent",
        "patterns": ["broken", "not working", "bug", "error", "crash", "fails", "undefined", "null", "white screen", "500", "404"],
        "skills": ["investigate"],
        "weight": "high",
        "_comment": "Bug reports trigger root cause investigation, not guessing"
      },
      "user-asks-for-variants": {
        "detect_by": "intent",
        "patterns": ["options", "alternatives", "variants", "different approaches", "try a few", "explore", "what if"],
        "skills": ["design-variants"],
        "weight": "normal"
      },
      "user-wants-review-before-build": {
        "detect_by": "intent",
        "patterns": ["before we build", "before coding", "review the plan", "is this plan good", "review this approach", "sanity check"],
        "skills": ["full-review"],
        "weight": "normal"
      },
      "user-asks-retro": {
        "detect_by": "intent",
        "patterns": ["retro", "retrospective", "how did this week go", "what shipped", "weekly update", "progress report"],
        "skills": ["retro"],
        "weight": "normal"
      },
      "thread-has-commits": {
        "detect_by": "context",
        "condition": "thread has 1+ commits and conversation is wrapping up (user says !merge, or no new messages for 60s)",
        "skills": ["learn"],
        "weight": "normal",
        "_comment": "Extract learnings from every productive thread"
      },
      "protected-file-touched": {
        "detect_by": "content",
        "content_patterns": ["cannotModify", "migration", "schema", "payment", ".env", "ci/cd", "pipeline", "deploy"],
        "skills": ["safety-guard"],
        "weight": "critical",
        "_comment": "Agent should check before committing to protected areas"
      }
    },

    "routing_philosophy": "The agent decides what to run based on the full context: what changed, what the user asked, how many iterations happened, what was already checked. No hard limits. Sometimes zero skills are right (simple content edit). Sometimes five are right (big refactor before merge). Use judgment, not rules."
  },

